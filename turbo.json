{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "test": {
      "inputs": ["apps/*/src/**/*.test.*", "packages/*/src/**/*.test.*"],
      "cache": false
    },
    "lint": {
      "inputs": ["apps/*/src/**", "apps/*/app/**", "packages/*/src/**"],
      "cache": false
    },
    "format": {
      "inputs": ["apps/*/src/**", "apps/*/app/**", "packages/*/src/**"],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**"],
      "env": ["BASE", "npm_package_version"]
    },
    "build-packages": {
      "dependsOn": [],
      "outputs": ["packages/*/dist/**"],
      "inputs": ["packages/*/src/**", "packages/*/package.json"]
    },
    "dev": {
      "dependsOn": ["build-packages"],
      "persistent": true,
      "cache": false
    }
  }
}